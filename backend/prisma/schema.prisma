generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ──────────────────────────────────────────────────────────────────

enum Role {
  USER
  MENTOR
  ADMIN
}

enum WeekFillStatus {
  MATERIALIZED
  CLEARED
  MANUAL
}

enum CallType {
  RESUME_REVAMP
  JOB_MARKET_GUIDANCE
  MOCK_INTERVIEW
}

enum CallRequestStatus {
  PENDING
  MATCHED
  BOOKED
  CANCELLED
}

enum BookingStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

// ─── Core User ───────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(USER)
  timezone  String   @default("UTC")
  createdAt DateTime @default(now()) @map("created_at")

  // Availability relations (existing — do not break)
  availabilityAsUser     Availability[]         @relation("UserAvailability")
  availabilityAsMentor   Availability[]         @relation("MentorAvailability")
  availabilityTemplate   AvailabilityTemplate?  @relation("UserTemplate")
  mentorTemplate         AvailabilityTemplate?  @relation("MentorTemplate")
  availabilityExceptions AvailabilityException[] @relation("UserExceptions")
  mentorExceptions       AvailabilityException[] @relation("MentorExceptions")
  availabilityWeekMeta   AvailabilityWeekMeta[] @relation("UserWeekMeta")
  mentorWeekMeta         AvailabilityWeekMeta[] @relation("MentorWeekMeta")

  // Legacy meeting relation (kept for DB compatibility)
  meetingsAsAdmin Meeting[] @relation("AdminMeetings")

  // New profile relations
  userProfile   UserProfile?
  mentorProfile MentorProfile?

  // Call request & booking relations
  callRequests      CallRequest[] @relation("UserCallRequests")
  bookingsAsUser    Booking[]     @relation("BookingUser")
  bookingsAsMentor  Booking[]     @relation("BookingMentor")
}

// ─── Profiles ────────────────────────────────────────────────────────────────

model UserProfile {
  id             String  @id @default(uuid())
  userId         String  @unique @map("user_id")
  // Tags
  isTech         Boolean @default(false) @map("is_tech")
  goodComm       Boolean @default(false) @map("good_comm")
  asksQuestions  Boolean @default(false) @map("asks_questions")
  // Free-text
  description    String  @default("")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

model MentorProfile {
  id            String  @id @default(uuid())
  mentorId      String  @unique @map("mentor_id")
  // Tags
  isTech        Boolean @default(false) @map("is_tech")
  bigCompany    Boolean @default(false) @map("big_company")
  country       String  @default("") // "India" | "Ireland" | etc.
  seniorDev     Boolean @default(false) @map("senior_dev")
  goodComm      Boolean @default(false) @map("good_comm")
  // Free-text (admin-editable)
  description   String  @default("")

  mentor User @relation(fields: [mentorId], references: [id], onDelete: Cascade)

  @@map("mentor_profiles")
}

// ─── Call Requests ────────────────────────────────────────────────────────────

model CallRequest {
  id          String            @id @default(uuid())
  userId      String            @map("user_id")
  callType    CallType          @map("call_type")
  description String            @default("")
  status      CallRequestStatus @default(PENDING)
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")

  user    User     @relation("UserCallRequests", fields: [userId], references: [id], onDelete: Cascade)
  booking Booking?

  @@index([userId], map: "call_requests_user_id_idx")
  @@index([status], map: "call_requests_status_idx")
  @@map("call_requests")
}

// ─── Bookings ────────────────────────────────────────────────────────────────

model Booking {
  id            String        @id @default(uuid())
  callRequestId String        @unique @map("call_request_id")
  userId        String        @map("user_id")
  mentorId      String        @map("mentor_id")
  callType      CallType      @map("call_type")
  scheduledAt   DateTime      @map("scheduled_at") // stored UTC
  durationMins  Int           @default(60) @map("duration_mins")
  meetLink      String?       @map("meet_link")
  status        BookingStatus @default(SCHEDULED)
  notes         String?
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  callRequest CallRequest @relation(fields: [callRequestId], references: [id], onDelete: Cascade)
  user        User        @relation("BookingUser", fields: [userId], references: [id])
  mentor      User        @relation("BookingMentor", fields: [mentorId], references: [id])

  @@index([userId], map: "bookings_user_id_idx")
  @@index([mentorId], map: "bookings_mentor_id_idx")
  @@index([scheduledAt], map: "bookings_scheduled_at_idx")
  @@map("bookings")
}

// ─── Existing Availability Models (unchanged) ─────────────────────────────────

model Availability {
  id        String   @id @default(uuid())
  userId    String?  @map("user_id")
  mentorId  String?  @map("mentor_id")
  role      Role
  date      DateTime @db.Date
  startTime DateTime @map("start_time")
  endTime   DateTime @map("end_time")
  createdAt DateTime @default(now()) @map("created_at")

  user   User? @relation("UserAvailability", fields: [userId], references: [id], onDelete: Cascade)
  mentor User? @relation("MentorAvailability", fields: [mentorId], references: [id], onDelete: Cascade)

  @@unique([userId, date, startTime], map: "availabilities_user_id_date_start_time_key")
  @@unique([mentorId, date, startTime], map: "availabilities_mentor_id_date_start_time_key")
  @@index([userId], map: "availabilities_user_id_idx")
  @@index([mentorId], map: "availabilities_mentor_id_idx")
  @@index([role], map: "availabilities_role_idx")
  @@index([date], map: "availabilities_date_idx")
  @@index([userId, date], map: "availabilities_user_id_date_idx")
  @@index([mentorId, date], map: "availabilities_mentor_id_date_idx")
  @@index([role, date], map: "availabilities_role_date_idx")
  @@map("availabilities")
}

model AvailabilityTemplate {
  id        String   @id @default(uuid())
  userId    String?  @unique @map("user_id")
  mentorId  String?  @unique @map("mentor_id")
  role      Role
  slots     Json     @default("[]")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user   User? @relation("UserTemplate", fields: [userId], references: [id], onDelete: Cascade)
  mentor User? @relation("MentorTemplate", fields: [mentorId], references: [id], onDelete: Cascade)

  @@map("availability_templates")
}

model AvailabilityException {
  id        String   @id @default(uuid())
  userId    String?  @map("user_id")
  mentorId  String?  @map("mentor_id")
  role      Role
  weekStart DateTime @map("week_start") @db.Date
  dayOfWeek Int      @map("day_of_week")
  hour      Int
  enabled   Boolean
  createdAt DateTime @default(now()) @map("created_at")

  user   User? @relation("UserExceptions", fields: [userId], references: [id], onDelete: Cascade)
  mentor User? @relation("MentorExceptions", fields: [mentorId], references: [id], onDelete: Cascade)

  @@unique([userId, weekStart, dayOfWeek, hour], map: "availability_exceptions_user_week_slot_key")
  @@unique([mentorId, weekStart, dayOfWeek, hour], map: "availability_exceptions_mentor_week_slot_key")
  @@map("availability_exceptions")
}

model AvailabilityWeekMeta {
  id        String         @id @default(uuid())
  userId    String?        @map("user_id")
  mentorId  String?        @map("mentor_id")
  role      Role
  weekStart DateTime       @map("week_start") @db.Date
  status    WeekFillStatus
  updatedAt DateTime       @updatedAt @map("updated_at")

  user   User? @relation("UserWeekMeta", fields: [userId], references: [id], onDelete: Cascade)
  mentor User? @relation("MentorWeekMeta", fields: [mentorId], references: [id], onDelete: Cascade)

  @@unique([userId, weekStart], map: "availability_week_meta_user_week_key")
  @@unique([mentorId, weekStart], map: "availability_week_meta_mentor_week_key")
  @@map("availability_week_meta")
}

// ─── Legacy Meeting (kept for DB compatibility) ───────────────────────────────

model Meeting {
  id              String   @id @default(uuid())
  adminId         String   @map("admin_id")
  title           String
  startTime       DateTime @map("start_time")
  endTime         DateTime @map("end_time")
  meetLink        String?  @map("meet_link")
  calendarEventId String?  @map("calendar_event_id")
  googleEventId   String?  @map("google_event_id")
  createdAt       DateTime @default(now()) @map("created_at")

  admin        User                 @relation("AdminMeetings", fields: [adminId], references: [id], onDelete: Cascade)
  participants MeetingParticipant[]
}

model MeetingParticipant {
  id        String @id @default(uuid())
  meetingId String @map("meeting_id")
  email     String

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@unique([meetingId, email])
  @@map("meeting_participants")
}
